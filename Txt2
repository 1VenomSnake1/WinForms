-- =========================================================
-- ПРОВЕРКА ОПЛАТЫ ЗАКАЗА
-- =========================================================

CREATE OR REPLACE FUNCTION update_order_payment()
RETURNS TRIGGER AS
$$
BEGIN

    UPDATE CustomerOrder
    SET is_paid =
    (
        (
            SELECT COALESCE(SUM(payment_sum),0)
            FROM Payment
            WHERE id_order =
            CASE
                WHEN TG_OP = 'DELETE'
                    THEN OLD.id_order
                ELSE NEW.id_order
            END
        )
        >=
        (
            SELECT total_sum
            FROM CustomerOrder
            WHERE id =
            CASE
                WHEN TG_OP = 'DELETE'
                    THEN OLD.id_order
                ELSE NEW.id_order
            END
        )
    )
    WHERE id =
    CASE
        WHEN TG_OP = 'DELETE'
            THEN OLD.id_order
        ELSE NEW.id_order
    END;

    RETURN NULL;

END;
$$ LANGUAGE plpgsql;

-- =========================================================
-- ТРИГГЕР ОПЛАТЫ
-- =========================================================

CREATE TRIGGER trg_update_order_payment
AFTER INSERT OR UPDATE OR DELETE
ON Payment
FOR EACH ROW
EXECUTE FUNCTION update_order_payment();

-- =========================================================
-- ПРЕДСТАВЛЕНИЕ ОСТАТКОВ НА СКЛАДЕ
-- =========================================================

CREATE OR REPLACE VIEW vw_stock AS
SELECT
    p.id,
    p.name,

    COALESCE(in_sum.total_in,0)
    -
    COALESCE(out_sum.total_out,0)
    AS stock

FROM Product p

LEFT JOIN
(
    SELECT
        id_product,
        SUM(quantity) AS total_in
    FROM InvoiceInInfo
    GROUP BY id_product
) in_sum
ON in_sum.id_product = p.id

LEFT JOIN
(
    SELECT
        id_product,
        SUM(quantity) AS total_out
    FROM InvoiceOutInfo
    GROUP BY id_product
) out_sum
ON out_sum.id_product = p.id;

-- =========================================================
-- ТОВАРЫ ЕСТЬ НА СКЛАДЕ,
-- НО ЗАКАЗ НЕ ОПЛАЧЕН
-- =========================================================

CREATE OR REPLACE VIEW vw_unpaid_orders AS
SELECT
    co.id AS order_id,
    c.fullname,
    p.name AS product_name,
    coi.quantity,
    coi.price,
    coi.quantity * coi.price AS total_sum

FROM CustomerOrder co

JOIN Client c
ON c.id = co.id_client

JOIN CustomerOrderInfo coi
ON coi.id_order = co.id

JOIN Product p
ON p.id = coi.id_product

JOIN vw_stock s
ON s.id = p.id

WHERE co.is_paid = FALSE
AND s.stock >= coi.quantity;

